# =============================================
# MovieRec-NNCF 环境变量配置模板
# 使用方式: 复制为 .env 并填入实际值
# =============================================

# ----- MySQL (本地实例) -----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=MovieRec
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password_here

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Kafka -----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ----- FastAPI 推理边车 -----
NUM_USERS=200948
NUM_MOVIES=84432
MODEL_PATH=../model/model.pth

# ----- Spring Boot -----
SIDECAR_URL=http://127.0.0.1:8000
